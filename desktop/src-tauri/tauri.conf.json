{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sprout",
  "version": "0.1.0",
  "identifier": "com.wesb.sprout",
  "build": {
    "beforeDevCommand": {
      "script": "exec ./node_modules/.bin/vite",
      "cwd": "..",
      "wait": false
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 600,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 12, "y": 22 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
